{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://YOUR-BACKEND-URL.onrender.com/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/s/:id",
      "destination": "https://matrimonial-mern-backend.onrender.com/api/profile/share/:id"
    }

  ]
}